/** * GLOBAL CONSTANTS 
 */
const SOURCE_SHEET = "WIP";
const LOG_SHEET = "Time log";
const SUMMARY_SHEET = "Daily Summary";
const STATUS_COL = 9; // Column I

/**
 * 1. REAL-TIME UPDATES (onEdit)
 */
function onEdit(e) {
  const ss = e.source;
  const sheet = ss.getActiveSheet();
  const range = e.range;

  if (sheet.getName() === SOURCE_SHEET && range.getColumn() === STATUS_COL) {
    const row = range.getRow();
    if (row < 2) return;

    const now = new Date();
    const tz = ss.getSpreadsheetTimeZone();
    const dateStamp = Utilities.formatDate(now, tz, "yyyy-MM-dd");
    const timeStamp = Utilities.formatDate(now, tz, "HH:mm:ss");

    const rowValues = sheet.getRange(row, 1, 1, 12).getValues()[0];
    const newStatus = String(e.value || "").trim().toUpperCase();
    const oldStatus = String(e.oldValue || "").trim().toUpperCase();

    if (!e.value || newStatus === oldStatus) return;

    // --- LOGGING ---
    const logSheet = ss.getSheetByName(LOG_SHEET);
    if (logSheet) {
      logSheet.appendRow([
        rowValues[0], rowValues[1], rowValues[2], rowValues[3], 
        rowValues[4], rowValues[5], rowValues[6], rowValues[7], 
        e.value, rowValues[9], rowValues[10], rowValues[11], 
        dateStamp, timeStamp
      ]);
    }

    // --- UPDATE MASUK & KELUAR ---
    updateSummaryCounts(ss, oldStatus, newStatus);

    // --- SORT WIP ---
    SpreadsheetApp.flush();
    const lastRowWip = sheet.getLastRow();
    if (lastRowWip > 1) {
      sheet.getRange(2, 1, lastRowWip - 1, 12).sort([
        {column: 9, ascending: true}, 
        {column: 1, ascending: true}
      ]);
    }
  }
}

/**
 * Helper to adjust Masuk/Keluar and trigger calculation
 */
function updateSummaryCounts(ss, oldStatus, newStatus) {
  const summarySheet = ss.getSheetByName(SUMMARY_SHEET);
  if (!summarySheet) return;

  const lastRow = summarySheet.getLastRow();
  if (lastRow < 2) return;

  const data = summarySheet.getRange(2, 1, lastRow - 1, 1).getValues();
  
  for (let i = 0; i < data.length; i++) {
    let statusName = String(data[i][0]).trim().toUpperCase();
    let rowIdx = i + 2;

    if (oldStatus && statusName === oldStatus) {
      let cellKeluar = summarySheet.getRange(rowIdx, 4); // Col D
      cellKeluar.setValue((Number(cellKeluar.getValue()) || 0) + 1);
    }

    if (statusName === newStatus) {
      if (newStatus === "PENYERAHAN") {
        let cellKeluarFinal = summarySheet.getRange(rowIdx, 4); 
        cellKeluarFinal.setValue((Number(cellKeluarFinal.getValue()) || 0) + 1);
      } else {
        let cellMasuk = summarySheet.getRange(rowIdx, 3); // Col C
        cellMasuk.setValue((Number(cellMasuk.getValue()) || 0) + 1);
      }
    }
  }
  // After updating Masuk/Keluar, recalculate Closing
  calculateClosing(summarySheet);
}

/**
 * 2. CLOSING CALCULATION
 * Math: Awal + Masuk - Keluar
 */
function calculateClosing(sheet) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;
  
  const range = sheet.getRange(2, 2, lastRow - 1, 3); // Cols B (Awal), C (Masuk), D (Keluar)
  const values = range.getValues();

  const results = values.map(row => {
    const awal = Number(row[0]) || 0;
    const masuk = Number(row[1]) || 0;
    const keluar = Number(row[2]) || 0;
    return [awal + masuk - keluar];
  });

  sheet.getRange(2, 5, results.length, 1).setValues(results); // Set Col E (Closing)
}

/**
 * 3. DAILY RESET (12 AM - 1 AM)
 * Sets tomorrow's Awal, and wipes Masuk, Keluar, and Closing to 0.
 */
function dailyRollover() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const summarySheet = ss.getSheetByName(SUMMARY_SHEET);
  if (!summarySheet) return;

  const lastRow = summarySheet.getLastRow();
  if (lastRow < 2) return;

  // We need the CURRENT closing values before we wipe them
  const currentData = summarySheet.getRange(2, 5, lastRow - 1, 1).getValues();

  const resetData = currentData.map(row => {
    const yesterdayClosing = Number(row[0]) || 0;
    // Format: [Awal, Masuk, Keluar, Closing]
    return [yesterdayClosing, 0, 0, 0]; 
  });

  // Write the reset data back to columns B, C, D, and E
  summarySheet.getRange(2, 2, resetData.length, 4).setValues(resetData);
  
  console.log("Midnight Reset: Awal updated, others reset to 0.");
}

/**
 * 4. SNAPSHOT TRIGGER (4 PM / 2 PM)
 */
function performDailySnapshot() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const summarySheet = ss.getSheetByName(SUMMARY_SHEET);
  calculateClosing(summarySheet);
  console.log("Manual Snapshot/Calculation performed.");
}
